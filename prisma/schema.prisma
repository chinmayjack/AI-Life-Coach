datasource db {
  provider = "sqlite" // Use "postgresql" for production
  url      = env("DATABASE_URL") // Local: file:./dev.db
}

generator client {
  provider = "prisma-client-js"
}

model Scenario {
  id        Int      @id @default(autoincrement())
  scenario  String
  result    String
  feedback  String?
  createdAt DateTime @default(now())
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  createdAt     DateTime       @default(now())
  conversations Conversation[] // optional: link user to conversations
}

model Conversation {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  persona     String
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])
  messages    Message[]
}

model Message {
  id             Int          @id @default(autoincrement())
  role           String       // "user" or "assistant"
  content        String
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())
}
