datasource db {
  provider = "sqlite" // change to "postgresql" later
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Feedback {
  id        Int      @id @default(autoincrement())
  scenario  String
  analysis  String
  rating    Int?
  createdAt DateTime @default(now())
}
